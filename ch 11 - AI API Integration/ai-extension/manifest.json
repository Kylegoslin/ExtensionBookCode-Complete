{
  "manifest_version": 3,
  "name": "Explain Words",
  "description": "Explain Words",
  "version": "1.0",
    "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "contextMenus",
    "notifications"
  ],
   "background": {
    "service_worker": "service-worker.js"
  },
   "side_panel": {
    "default_path": "side.html"
  },
  
   "host_permissions": [
    "http://localhost:3000/*" 
  ],
   "action": {
    "default_title": "Click to open panel",
    "default_icon": "icon.png"
  }
}
