{
  "manifest_version": 3,
  "name": "Background changer",
  "description": "Background changer",
  "version": "1.0",
  "action": {
    "default_popup": "popup_interface.html",
    "default_icon": "icon.png"
  },
    "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
   {
     "matches": ["https://*.google.com/*"],
     "js": ["contentscript.js"]
   }]
}
