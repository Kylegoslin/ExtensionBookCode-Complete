{
  "manifest_version": 3,
  "name": "Background changer button",
  "description": "Background changer - button",
  "version": "1.0",
    "permissions": [
    "activeTab",
    "scripting"
  ],
 "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Click me!",
    "default_icon": "icon.png"
  }
}
